{
  "name": "pipeline-table-editor",
  "version": "1.0.1",
  "description": "Static web editor for instruction-time pipeline tables.",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "version": "npm run version:sync",
    "version:sync": "tsx scripts/sync-version-docs.ts",
    "audit:file-sizes": "tsx scripts/audit-file-sizes.ts",
    "audit:deps": "tsx scripts/audit-circular-deps.ts",
    "audit:layers": "tsx scripts/audit-layers.ts",
    "screenshots": "tsx tests/capture-screenshots.ts",
    "test:unit": "tsx tests/core.test.ts",
    "test:integration": "tsx tests/integration.test.ts",
    "test:all": "npm run test:unit && npm run test:integration && npm run test:smoke",
    "test:smoke": "tsx tests/browser-smoke.ts"
  },
  "devDependencies": {
    "playwright-core": "^1.60.0",
    "tsx": "^4.21.0",
    "typescript": "^5.8.3",
    "vite": "^8.0.16"
  }
}
